{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "lib": ["ES2022", "DOM"],

    "types": ["node", "@playwright/test"],

    "moduleResolution": "node16",
    "resolveJsonModule": true,
    "esModuleInterop": true,

    "strict": true,
    "skipLibCheck": true,

    "rootDir": ".",
    "outDir": "dist",

    "forceConsistentCasingInFileNames": true
  }
}